// Inventory Management App - Prisma Schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlserver"
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?   @db.NVarChar(Max)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id           String        @id @default(cuid())
  name         String
  sku          String        @unique
  barcode      String?       @unique
  description  String?       @db.NVarChar(Max)
  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id])
  manufacturer String?
  model        String?
  unitCost     Float         @default(0)
  reorderPoint Int           @default(5)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  inventory    Inventory?
  transactions Transaction[]
  allocations  Allocation[]
  stockItems   StockItem[]
}

model Inventory {
  id        String   @id @default(cuid())
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(0)
  location  String?
  updatedAt DateTime @updatedAt
}

model Customer {
  id             String        @id @default(cuid())
  name           String
  email          String?
  phone          String?
  company        String?
  address        String?       @db.NVarChar(Max)
  accountManager String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  allocations    Allocation[]
  transactions   Transaction[]
}

model Transaction {
  id              String      @id @default(cuid())
  type            String
  productId       String
  product         Product     @relation(fields: [productId], references: [id])
  customerId      String?
  customer        Customer?   @relation(fields: [customerId], references: [id])
  quantity        Int
  reference       String?
  notes           String?     @db.NVarChar(Max)
  performedBy     String?
  createdAt       DateTime    @default(now())
  dispatchedItems StockItem[] @relation("DispatchedByTransaction")
}

model Allocation {
  id          String           @id @default(cuid())
  productId   String
  product     Product          @relation(fields: [productId], references: [id])
  customerId  String
  customer    Customer         @relation(fields: [customerId], references: [id])
  quantity    Int
  status      String           @default("PENDING")
  reference   String?
  notes       String?          @db.NVarChar(Max)
  allocatedAt DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  items       AllocationItem[]
}

model AllocationItem {
  id           String      @id @default(cuid())
  allocationId String
  allocation   Allocation  @relation(fields: [allocationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  stockItemId  String?     @unique
  stockItem    StockItem?  @relation(fields: [stockItemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  serialNumber String?
  assetTag     String?
  notes        String?     @db.NVarChar(Max)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model StockItem {
  id                      String          @id @default(cuid())
  productId               String
  product                 Product         @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  barcode                 String?         @unique
  serialNumber            String?
  assetTag                String?
  status                  String          @default("AVAILABLE")
  location                String?
  notes                   String?         @db.NVarChar(Max)
  receivedRef             String?
  dispatchedTransactionId String?
  dispatchedTransaction   Transaction?    @relation("DispatchedByTransaction", fields: [dispatchedTransactionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  allocationItem          AllocationItem?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
}

model Settings {
  id    String @id @default("global")
  key   String @unique
  value String @db.NVarChar(Max)
}

// SQL Server does not support enums — TransactionType, AllocationStatus and StockItemStatus are stored as String
